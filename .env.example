# FastAPI
# APP_NAME="Robot Dev Team Webhook Listener"
APP_HOST=127.0.0.1
APP_PORT=8080
APP_LOG_LEVEL=INFO

# Webhook secret shared with GitLab project settings (leave blank to disable)
GITLAB_WEBHOOK_SECRET=

# GitLab instance
GLAB_HOST=gitlab.example.com

# Token for glab CLI used by the app process for enrichment and auto-unassign.
# Requires `api` scope when ENABLE_AUTO_UNASSIGN is enabled (to modify assignees).
# If auto-unassign is disabled, `read_api` scope is sufficient.
GLAB_TOKEN=

# Path to routing configuration (override to use a local routes file)
# ROUTE_CONFIG_PATH=config/routes.local.yaml

# Directory for prompt templates used by agent dispatch
# PROMPT_DIR=prompts

# Directory where agent run logs are written
# RUN_LOGS_DIR=run-logs

# Optional: turn on route hot reloading
DEBUG_RELOAD_ROUTES=false

# Timeout for glab CLI subprocess calls (seconds)
# GLAB_TIMEOUT_SECONDS=30

# Agent execution timeouts
# Wall-clock: hard upper bound on total run duration (seconds)
AGENT_MAX_WALL_CLOCK_SECONDS=7200
# Inactivity: watchdog resets on stdout output only (seconds)
AGENT_MAX_INACTIVITY_SECONDS=900
# Grace period: SIGTERM before SIGKILL on timeout (seconds)
AGENT_TIMEOUT_GRACE_SECONDS=10

# Agents to notify when @all/@agents is used (comma-separated)
ALL_MENTIONS_AGENTS=claude,gemini,codex

# Enable the live dashboard UI (true/false)
LIVE_DASHBOARD_ENABLED=false

# Log pruning
LOG_PRUNING_ENABLED=true
LOG_RETENTION_DAYS=7
LOG_PRUNING_INTERVAL_HOURS=24

# Branch pruning (auto-remove remote branches merged into base branch)
BRANCH_PRUNING_ENABLED=false
BRANCH_PRUNING_INTERVAL_HOURS=24
BRANCH_PRUNING_DRY_RUN=true
BRANCH_PRUNING_BASE_BRANCH=main
BRANCH_PRUNING_PROTECTED_PATTERNS=main,master,HEAD,backup/*
BRANCH_PRUNING_AGENT=claude
BRANCH_PRUNING_MIN_AGE_HOURS=24

# Default agent models
CLAUDE_MODEL=claude-opus-4-6
GEMINI_MODEL=gemini-3.1-pro-preview
CODEX_MODEL=gpt-5.4

# npm cache path inside the container
# NPM_CACHE_DIR=/work/.npm-cache

# Project repositories mount path is configured directly in docker-compose.yml.
# Edit the volume mounts for /work/projects and /work/projects-ro to point to your
# projects directory. Projects should be organized as: <namespace>/<project-name>

# Enable on-demand repository cloning when a webhook arrives for a project
# that doesn't exist locally. Requires agent GitLab tokens to be configured.
ENABLE_AUTO_CLONE=false

# Clone depth for auto-cloned repositories.
# 0 = full history (recommended for agents that need git log/blame)
# 1+ = shallow clone (faster initial clone, limited history)
AUTO_CLONE_DEPTH=0

# Enable automatic branch switching before agent dispatch.
# When enabled, the system will:
# - For MR events: checkout the source branch
# - For issues with linked MRs: checkout the MR's source branch
# - For new issues (no MR): checkout the default branch (usually main)
# If uncommitted changes exist, they are backed up to a timestamped branch
# and pushed to origin before switching.
ENABLE_BRANCH_SWITCH=false

# Enable smart branch selection for issue/note events (default: true).
# When enabled, uses GitLab's closes_issues API to prefer MRs that explicitly
# close the current issue, avoiding false positives from mention-only links.
# When disabled, falls back to the original "first linked open MR" behavior.
ENABLE_SMART_BRANCH_SELECTION=true

# Automatically unassign agent after successful task completion
# when the task was triggered by agent assignment (default: false)
ENABLE_AUTO_UNASSIGN=false

# Post a GitLab comment when an auto-backup branch is created
# during branch resolution (default: true)
ENABLE_BACKUP_NOTIFICATIONS=true

# Hold window (seconds) for mention-triggered dispatches. If an assignment
# webhook for the same agent+project+IID arrives within this window, the
# mention is suppressed to avoid duplicate responses. Set to 0 to disable.
MENTION_HOLD_SECONDS=3.0

# Agent-specific GitLab tokens and identities (used by glab-usr).
# Naming convention: for agent "foo-bar", use FOO_BAR_AGENT_GITLAB_TOKEN, etc.
# See docs/ADDING_AN_AGENT.md for the full onboarding guide.
CLAUDE_AGENT_GITLAB_TOKEN=
CLAUDE_AGENT_GIT_NAME="Claude Agent"
CLAUDE_AGENT_GIT_EMAIL=claude@example.com

GEMINI_AGENT_GITLAB_TOKEN=
GEMINI_AGENT_GIT_NAME="Gemini Agent"
GEMINI_AGENT_GIT_EMAIL=gemini@example.com

CODEX_AGENT_GITLAB_TOKEN=
CODEX_AGENT_GIT_NAME="Codex Agent"
CODEX_AGENT_GIT_EMAIL=codex@example.com

# Custom agent example (uncomment and configure for your agent):
# QWEN_CODE_AGENT_GITLAB_TOKEN=
# QWEN_CODE_AGENT_GIT_NAME="Qwen Code Agent"
# QWEN_CODE_AGENT_GIT_EMAIL=qwen-code@example.com
# QWEN_CODE_MODEL=qwen-coder-latest

# Recommended: map container user to host user (set to output of `id -u` / `id -g`)
# Required on Linux when host UID/GID differs from 1000 to avoid bind-mount permission errors
# Defaults to 1000 if unset (see docker-compose.yml)
LOCAL_UID=
LOCAL_GID=

[sources]
# Add extra suffixes (e.g., [".proto", ".cfg"]) to include more file types.
extra_suffixes = []
# Add specific filenames (without suffixes) that should always be checked.
extra_filenames = []

[exclusions]
# Add path prefixes to skip during validation (e.g., ["build/", "dist/"]).
prefixes = []

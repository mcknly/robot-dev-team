# Copyright (c) 2025 MCKNLY LLC
#
# Copy this file to gitlab/.env and fill in the values before starting GitLab.
# Never commit gitlab/.env — it contains secrets.

# GitLab admin Personal Access Token with 'api' scope.
# Cannot be created until after GitLab first boots.
# Procedure: start GitLab, create a PAT in the UI, then paste it here and
# run: docker compose -f gitlab/docker-compose.gitlab.yml restart
GITLAB_ADMIN_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# URL where the Robot Dev Team webhook listener is reachable FROM INSIDE the
# GitLab container.  The docker-compose.gitlab.yml adds an extra_hosts entry
# that maps 'host.docker.internal' to the Docker host on Linux, so the name
# works identically on Linux, macOS, and Windows (WSL2 + Docker Desktop).
# Port must match the host-side mapping for the robot-dev-team container
# (APP_PORT in robot-dev-team/.env, default 8080 inside → 8080 on host).
ROBOT_WEBHOOK_URL=http://host.docker.internal:8080/webhooks/gitlab

# Shared secret — must match GITLAB_WEBHOOK_SECRET in robot-dev-team/.env.
# Leave blank to disable webhook authentication.
GITLAB_WEBHOOK_SECRET=

# Set to 'false' when using plain HTTP or self-signed TLS certificates.
GITLAB_WEBHOOK_SSL_VERIFY=false

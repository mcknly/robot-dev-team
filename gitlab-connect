handle_issue() {
  local action=""
  local -a rest=()

  if [[ $# -eq 0 ]]; then
    print_issue_usage >&2
    exit 1
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
      create|edit|comment|view|get|show)
        if [[ -z "$action" ]]; then
          action="$(normalize_issue_action "$1")"
        else
          rest+=("$1")
        fi
        shift
        ;;
      -m|--mode)
        [[ $# -ge 2 ]] || die "Missing value for $1"
        action="$(normalize_issue_action "$2")"
        shift 2
        ;;
      -h|--help)
        print_issue_usage
        exit 0
        ;;
      *)
        rest+=("$1")
        shift
        ;;
    esac
  done

  [[ -n "$action" ]] || { print_issue_usage >&2; exit 1; }
  case "$action" in
    create) issue_create "${rest[@]}" ;;
    edit) issue_edit "${rest[@]}" ;;
    comment) issue_comment "${rest[@]}" ;;
    view) issue_view "${rest[@]}" ;;
    *) die "Unsupported issue action: $action" ;;
  esac
}


handle_auth() {
  local agent_override="${AGENT_OVERRIDE:-}"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -a|--agent)
        [[ $# -ge 2 ]] || die "Missing value for $1"
        agent_override="$2"
        shift 2
        ;;
      -h|--help)
        cat <<'USAGE'
Usage: gitlab-connect auth [--agent NAME]

Authenticate the GitLab CLI for the requested agent account.
If no agent is provided, the command falls back to --agent, CURRENT_AGENT, or ROBOT_AGENT_NAME.
USAGE
        exit 0
        ;;
      --)
        shift
        break
        ;;
      *)
        if [[ -z "$agent_override" ]]; then
          agent_override="$1"
          shift
        else
          die "Unexpected argument: $1"
        fi
        ;;
    esac
  done

  if [[ -z "$agent_override" ]]; then
    agent_override="$(determine_agent)"
  fi
  authenticate_agent "$agent_override"
}

determine_agent() {
  if [[ -n "${AGENT_OVERRIDE:-}" ]]; then
    printf '%s' "$AGENT_OVERRIDE"
    return
  fi
  if [[ -n "${CURRENT_AGENT:-}" ]]; then
    printf '%s' "$CURRENT_AGENT"
    return
  fi
  if [[ -n "${ROBOT_AGENT_NAME:-}" ]]; then
    printf '%s' "$ROBOT_AGENT_NAME"
    return
  fi
  printf ''
}

# --- main ---

AGENT_OVERRIDE=""
AUTO_AUTH=1

while [[ $# -gt 0 ]]; do
  case "$1" in
    -a|--agent)
      [[ $# -ge 2 ]] || die "Missing value for $1"
      AGENT_OVERRIDE="$2"
      shift 2
      ;;
    --no-auth)
      AUTO_AUTH=0
      shift
      ;;
    -h|--help)
      print_main_usage
      exit 0
      ;;
    help)
      print_main_usage
      exit 0
      ;;
    auth|issue|mr)
      COMMAND="$1"
      shift
      break
      ;;
    *)
      COMMAND="$1"
      shift
      break
      ;;
  esac
 done

if [[ -z "${COMMAND:-}" ]]; then
  print_main_usage >&2
  exit 1
fi

case "$COMMAND" in
  auth)
    handle_auth "$@"
    exit $?
    ;;
  issue|mr)
    ;;
  *)
    die "Unknown command: $COMMAND"
    ;;
esac

# Detect read-only repo and resolve context for glab commands
resolve_repo_context

# In read-only repos, skip redundant re-authentication to avoid
# glab-usr attempting writes to .git/config (the router pre-authenticates)
if [[ "$READONLY_REPO" -eq 1 && "$AUTO_AUTH" -eq 1 && -z "${GITLAB_CONNECT_FORCE_AUTH:-}" ]]; then
  echo "[gitlab-connect] INFO: skipping re-authentication in read-only repo (pre-auth assumed)" >&2
  AUTO_AUTH=0
fi

if [[ "$AUTO_AUTH" -eq 1 ]]; then
  AGENT_SELECTED="$(determine_agent)"
  [[ -n "$AGENT_SELECTED" ]] || die "Unable to determine agent; set CURRENT_AGENT or use --agent"
  authenticate_agent "$AGENT_SELECTED"
fi

case "$COMMAND" in
  issue)
    handle_issue "$@"
    ;;
  mr)
    handle_mr "$@"
    ;;
esac